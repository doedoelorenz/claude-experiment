# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — your real secrets never enter the repo.

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Public URL where the GitHub Pages site is served.
# Used as the link in the daily Telegram notification.
SITE_URL=https://doedoelorenz.github.io/claude-experiment/
